{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "caracal-setup",
  "version": "2",
  "assetdir": "frontend/dist",
  "reloaddirs": "frontend/dist",
  "build:dir": "build",
  "frontend:dir": "frontend",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:install": "npm install",
  "frontend:dev:build": "npm run build",
  "wailsjsdir": "frontend/dist/wailsjs",
  "outputfilename": "caracal-setup",
  "debounceMS": 100,
  "info": {
    "companyName": "Caracal OS",
    "productName": "Caracal Setup",
    "productVersion": "0.1.0",
    "comments": "First-launch setup wizard for Caracal OS."
  },
  "bindings": {
    "ts_generation": {
      "outputType": "interfaces"
    }
  }
}
